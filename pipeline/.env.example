# Copy this file to `.env` and paste your key. `.env` is git-ignored, so the
# secret stays on your machine and never gets committed.
#
#   cp .env.example .env
#   then edit .env and paste your service_role key
#
# Get the key from Supabase dashboard -> Project Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional knobs (uncomment to use):
# STORE_LIMIT=5     # only scrape the first N stores (for testing)
# HEADLESS=1        # hide the browser window
# SLOW=1            # cautious pacing if a run gets flaky/blocked
